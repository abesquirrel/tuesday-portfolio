# Copy this to .env and fill in your values
# Add .env to .gitignore — commit only .env.example

# Your Cloudinary credentials (found in your Cloudinary Dashboard under "API Keys")
PUBLIC_CLOUDINARY_CLOUD_NAME=your_cloud_name_here
CLOUDINARY_API_KEY=your_api_key_here
CLOUDINARY_API_SECRET=your_api_secret_here

# The full connection string (often used by backend Node.js SDKs if you add them later)
CLOUDINARY_URL=cloudinary://API_KEY:API_SECRET@CLOUD_NAME

# ─── Cloudflare D1 ────────────────────────────────────────────────────────────
# D1 is bound via wrangler.toml — no environment variable needed.
# For local dev WITH D1:  npx wrangler pages dev -- npx astro dev
# For local dev WITHOUT:  npm run dev  (falls back to src/data/photos.json)
