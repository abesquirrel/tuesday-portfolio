# Copy this to .env and fill in your values
# Add .env to .gitignore — commit only .env.example

# Your Cloudinary cloud name (found in your Cloudinary dashboard)
PUBLIC_CLOUDINARY_CLOUD_NAME=your_cloud_name_here

# ─── Cloudflare D1 ────────────────────────────────────────────────────────────
# D1 is bound via wrangler.toml — no environment variable needed.
# For local dev WITH D1:  npx wrangler pages dev -- npx astro dev
# For local dev WITHOUT:  npm run dev  (falls back to src/data/photos.json)
