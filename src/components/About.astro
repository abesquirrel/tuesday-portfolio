// Swap this public_id when you upload your portrait to Cloudinary
const portraitUrl = cloudinaryUrl('portfolio/about/portrait', 'f_auto,q_auto,w_600,h_750,c_fill,g_face');

interface Props {
  settings: Record<string, string>;
}
const { settings } = Astro.props;

// Fallbacks for when settings aren't loaded (e.g. local dev without DB)
const bio = settings.about_bio || "My name is Paul Rojas. I shoot film — mostly street, mostly in places where nobody's watching. The name of this site isn't a mystery: most of my best rolls happen on completely unremarkable days that I only remember because I had a camera.";
const currentlyShooting = settings.about_currently_shooting || "Nikkormat FT2 · Nikon 50mm f/1.4 AI · Konica 100 VX / Kodak Color 200";
const developing = settings.about_developing || "HC-110 (Dilution B) · D-76 1:1";
const alsoShooting = settings.about_also_shooting || "Fujifilm X-T20 · Classic Chrome · Acros · Eterna Cinema";
---

<section id="about">
  <div class="container">
    <div class="row g-5 align-items-start">

      <div class="col-lg-4 reveal">
        <div class="about-portrait">
          <img
            src={portraitUrl}
            alt="Paul Rojas"
            width="600"
            height="750"
            loading="lazy"
          />
        </div>
      </div>

      <div class="col-lg-8 reveal">
        <p class="section-eyebrow">About</p>
        <h2 class="section-title mb-4" style="font-size:clamp(1.6rem,3vw,2.2rem);">
          The photographer behind the camera.
        </h2>

        <div class="about-body">
          <p set:html={bio.replace(/\n/g, '<br />')} />
        </div>

        <div class="camera-note">
          <strong>Currently shooting:</strong>&nbsp; {currentlyShooting}<br />
          <strong>Developing:</strong>&nbsp; {developing}<br />
          <strong>Also shooting:</strong>&nbsp; {alsoShooting}
        </div>
      </div>

    </div>
  </div>
</section>
