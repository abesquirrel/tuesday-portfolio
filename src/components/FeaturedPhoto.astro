---
import { cloudinaryFromRow } from '../utils/cloudinary';
import type { Photo } from '../types/photo';

interface Props {
  photo: Photo;
  cloudName?: string;
}
const { photo, cloudName } = Astro.props;

const fullUrl  = cloudinaryFromRow(photo, 'f_auto,q_auto,w_1600', cloudName);
const thumbUrl = cloudinaryFromRow(photo, 'f_auto,q_auto,w_900', cloudName);
---

<section id="featured">
  <div class="container">
    <div class="row mb-4 reveal">
      <div class="col-12">
        <p class="section-eyebrow">Featured Image</p>
        <h2 class="section-title" style="font-size:clamp(1.4rem,3vw,2rem);">This one stopped me.</h2>
      </div>
    </div>

    <div class="row align-items-center g-5">
      <div class="col-lg-8 reveal">
        <div class="featured-frame">
          <div class="featured-badge">Featured</div>
          <img
            src={thumbUrl}
            alt={photo.title}
            class="lightbox-trigger"
            data-full={fullUrl}
            data-meta={`${photo.location}${photo.camera ? ` · ${photo.camera}` : ''}${photo.film_stock ? ` · ${photo.film_stock}` : ''}${photo.roll ? ` · ${photo.roll}` : ''}`}
            loading="eager"
            width="900"
            height="600"
          />
        </div>
      </div>

      <div class="col-lg-4 reveal">
        <div class="featured-meta">
          <h3 class="featured-title">{photo.title}</h3>
          <p class="featured-caption">{photo.caption}</p>
          <p class="featured-detail">
            <span>↗</span>{photo.roll}
          </p>
          <p class="featured-detail">
            <span>◎</span>{photo.location}
          </p>
          {photo.camera && (
            <p class="featured-detail">
              <span>📷</span>{photo.camera} {photo.lens && `· ${photo.lens}`}
            </p>
          )}
          {photo.film_stock && (
            <p class="featured-detail">
              <span>🎞️</span>{photo.film_stock}
            </p>
          )}
          {photo.simulation && (
            <p class="featured-detail">
              <span>⬡</span>{photo.simulation}
            </p>
          )}
        </div>
      </div>
    </div>
  </div>
</section>
