---
import { cloudinaryUrl } from '../utils/cloudinary';

interface Props {
  publicId: string;
  title: string;
  caption: string;
  roll: string;
  location: string;
}
const { publicId, title, caption, roll, location } = Astro.props;

const fullUrl  = cloudinaryUrl(publicId, 'f_auto,q_auto,w_1600');
const thumbUrl = cloudinaryUrl(publicId, 'f_auto,q_auto,w_900');
---

<section id="featured">
  <div class="container">
    <div class="row mb-4 reveal">
      <div class="col-12">
        <p class="section-eyebrow">Featured Image</p>
        <h2 class="section-title" style="font-size:clamp(1.4rem,3vw,2rem);">This one stopped me.</h2>
      </div>
    </div>

    <div class="row align-items-center g-5">
      <div class="col-lg-8 reveal">
        <div class="featured-frame">
          <div class="featured-badge">Featured</div>
          <img
            src={thumbUrl}
            alt={title}
            class="lightbox-trigger"
            data-full={fullUrl}
            data-caption={`${title} — ${location}`}
            loading="eager"
            width="900"
            height="600"
          />
        </div>
      </div>

      <div class="col-lg-4 reveal">
        <div class="featured-meta">
          <h3 class="featured-title">{title}</h3>
          <p class="featured-caption">{caption}</p>
          <p class="featured-detail">
            <span>↗</span>{roll}
          </p>
          <p class="featured-detail">
            <span>◎</span>{location}
          </p>
        </div>
      </div>
    </div>
  </div>
</section>
