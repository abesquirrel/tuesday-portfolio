---
import { cloudinaryUrl, cloudinaryThumb } from '../utils/cloudinary';

interface Photo {
  id: string;
  publicId: string;
  title: string;
  caption: string;
  roll: string;
  location: string;
  isFeatured: boolean;
  medium?: 'film' | 'digital';
  simulation?: string;
}

interface Props {
  photos: Photo[];
}

const { photos } = Astro.props;
const gridPhotos = photos.filter((p) => !p.isFeatured);
---

<section id="gallery">
  <div class="container-fluid px-0">
    <div class="container mb-5 reveal">
      <p class="section-eyebrow">Film &amp; Simulation</p>
      <h2 class="section-title" style="font-size:clamp(1.4rem,3vw,2rem);">
        Everything else worth keeping.
      </h2>
    </div>

    <div class="gallery-grid">
      {
        gridPhotos.map((photo) => {
          const thumb = cloudinaryThumb(photo.publicId);
          const full  = cloudinaryUrl(photo.publicId, 'f_auto,q_auto,w_1400');
          return (
            <div class="gallery-cell">
              <img
                src={thumb}
                alt={photo.title}
                class="lightbox-trigger"
                data-full={full}
                data-caption={`${photo.title} — ${photo.location}`}
                loading="lazy"
                decoding="async"
              />
              <div class="gallery-cell-overlay">
                <p class="cell-title">{photo.title}</p>
                <p class="cell-meta">
                  {photo.roll} &nbsp;·&nbsp; {photo.location}
                  {photo.simulation && <>&nbsp;·&nbsp; <em>{photo.simulation}</em></>}
                </p>
              </div>
            </div>
          );
        })
      }
    </div>
  </div>
</section>
