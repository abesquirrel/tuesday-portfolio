---
import { cloudinaryFromRow, cloudinaryThumb } from '../utils/cloudinary';
import type { Photo, Album } from '../types/photo';

interface Props {
  photos: Photo[];
  albums: Album[];
  cloudName?: string;
}

const { photos, albums, cloudName } = Astro.props;
const gridPhotos = photos.filter((p) => p.is_featured === 0);

// Helper to get photos for a specific album
const getAlbumPhotos = (albumId: string | null) => 
  gridPhotos.filter(p => p.album_id === albumId);

// Albums that actually have photos
const activeAlbums = albums.filter(a => getAlbumPhotos(a.id).length > 0);
const uncategorizedPhotos = getAlbumPhotos(null);
---

<section id="gallery">
  <div class="container-fluid px-0">
    <div class="container mb-5 reveal">
      <p class="section-eyebrow">Film &amp; Simulation</p>
      <h2 class="section-title" style="font-size:clamp(1.4rem,3vw,2rem);">
        Everything else worth keeping.
      </h2>
    </div>

    {
      activeAlbums.map((album) => (
        <div class="album-section mb-5">
          <div class="container mb-4 reveal d-flex justify-content-between align-items-end">
            <div>
              <h3 class="album-title">{album.title}</h3>
              {album.description && <p class="album-description text-muted small mb-0">{album.description}</p>}
            </div>
            <button class="btn-view-album" data-album-id={album.id}>
              Browse Album <span>→</span>
            </button>
          </div>
          
          <div class="gallery-grid">
            {getAlbumPhotos(album.id).map((photo) => {
              const thumb = photo.cloudinary_url
                ? cloudinaryFromRow(photo, 'f_auto,q_auto,w_600,h_400,c_fill,g_auto', cloudName)
                : cloudinaryThumb(photo.public_id, cloudName);
              const full  = cloudinaryFromRow(photo, 'f_auto,q_auto,w_1400', cloudName);
              return (
                <div class="gallery-cell">
                  <img
                    src={thumb}
                    alt={photo.title}
                    class="lightbox-trigger"
                    data-full={full}
                    data-meta={`${photo.location}${photo.camera ? ` · ${photo.camera}` : ''}${photo.film_stock ? ` · ${photo.film_stock}` : ''}${photo.roll ? ` · ${photo.roll}` : ''}`}
                    loading="lazy"
                    decoding="async"
                  />
                  <div class="gallery-cell-overlay">
                    <p class="cell-title">{photo.title}</p>
                    <p class="cell-meta">
                      {photo.roll} &nbsp;·&nbsp; {photo.location}
                      {photo.camera && <>&nbsp;·&nbsp; {photo.camera}</>}
                      {photo.film_stock && <>&nbsp;·&nbsp; {photo.film_stock}</>}
                      {photo.simulation && <>&nbsp;·&nbsp; <em>{photo.simulation}</em></>}
                    </p>
                  </div>
                </div>
              );
            })}
          </div>
        </div>
      ))
    }

    {
      uncategorizedPhotos.length > 0 && (
        <div class="album-section mb-5">
          <div class="container mb-4 reveal d-flex justify-content-between align-items-end">
            <h3 class="album-title">Other Moments</h3>
            <button class="btn-view-album" data-album-id="uncategorized">
              Browse All <span>→</span>
            </button>
          </div>
          <div class="gallery-grid">
            {uncategorizedPhotos.map((photo) => {
              const thumb = photo.cloudinary_url
                ? cloudinaryFromRow(photo, 'f_auto,q_auto,w_600,h_400,c_fill,g_auto', cloudName)
                : cloudinaryThumb(photo.public_id, cloudName);
              const full  = cloudinaryFromRow(photo, 'f_auto,q_auto,w_1400', cloudName);
              return (
                <div class="gallery-cell">
                  <img
                    src={thumb}
                    alt={photo.title}
                    class="lightbox-trigger"
                    data-full={full}
                    data-meta={`${photo.location}${photo.camera ? ` · ${photo.camera}` : ''}${photo.film_stock ? ` · ${photo.film_stock}` : ''}${photo.roll ? ` · ${photo.roll}` : ''}`}
                    loading="lazy"
                    decoding="async"
                  />
                  <div class="gallery-cell-overlay">
                    <p class="cell-title">{photo.title}</p>
                    <p class="cell-meta">
                      {photo.roll} &nbsp;·&nbsp; {photo.location}
                      {photo.camera && <>&nbsp;·&nbsp; {photo.camera}</>}
                      {photo.film_stock && <>&nbsp;·&nbsp; {photo.film_stock}</>}
                      {photo.simulation && <>&nbsp;·&nbsp; <em>{photo.simulation}</em></>}
                    </p>
                  </div>
                </div>
              );
            })}
          </div>
        </div>
      )
    }
  </div>
</section>

<style>
  .album-title {
    font-family: 'Playfair Display', serif;
    font-size: 1.5rem;
    margin-bottom: 0.5rem;
    position: relative;
    display: inline-block;
  }
  .album-title::after {
    content: '';
    position: absolute;
    bottom: -5px;
    left: 0;
    width: 30px;
    height: 1px;
    background: currentColor;
    opacity: 0.3;
  }
  .album-description {
    letter-spacing: 0.05em;
    max-width: 600px;
  }
  .album-section {
    padding-top: 2rem;
  }
  .btn-view-album {
    background: rgba(255, 255, 255, 0.03);
    border: 1px solid rgba(255, 255, 255, 0.08);
    color: var(--silver-dim, #7a7671);
    font-family: 'Courier New', monospace;
    font-size: 0.65rem;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    cursor: pointer;
    transition: all 0.4s cubic-bezier(0.4, 0, 0.2, 1);
    padding: 0.6rem 1.4rem;
    display: flex;
    align-items: center;
    gap: 0.75rem;
    border-radius: 40px;
  }
  .btn-view-album span {
    transition: transform 0.4s cubic-bezier(0.4, 0, 0.2, 1);
    color: var(--accent-amber, #c8a96e);
    font-size: 1.1rem;
    line-height: 1;
  }
  .btn-view-album:hover {
    color: var(--off-white, #f0ede8);
    background: rgba(200, 169, 110, 0.1);
    border-color: rgba(200, 169, 110, 0.3);
  }
  .btn-view-album:hover span {
    transform: translateX(6px);
  }

  @media (max-width: 576px) {
    .btn-view-album {
      font-size: 0.6rem;
    }
  }
</style>
