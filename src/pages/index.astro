---
import BaseLayout from '../layouts/BaseLayout.astro';
import Masthead from '../components/Masthead.astro';
import FeaturedPhoto from '../components/FeaturedPhoto.astro';
import Gallery from '../components/Gallery.astro';
import About from '../components/About.astro';
import Contact from '../components/Contact.astro';
import '../styles/global.scss';

import { getPhotos, getSettings, getSocialLinks } from '../lib/db';
import type { Photo, SocialLink } from '../types/photo';

// Server-rendered so D1 bindings are available at request time
export const prerender = false;

const db = (Astro.locals as any).runtime?.env?.DB;
const photosData: Photo[] = await getPhotos(db);
const settings: Record<string, string> = await getSettings(db);
const socialLinks: SocialLink[] = await getSocialLinks(db);

const featuredPhoto = photosData.find((p) => p.is_featured === 1) || photosData[0];
---

<BaseLayout>
  <Masthead heroPublicId={featuredPhoto.public_id} />

  <FeaturedPhoto
    photo={featuredPhoto}
  />

  <Gallery photos={photosData} />

  <About settings={settings} />

  <Contact links={socialLinks} />
</BaseLayout>
