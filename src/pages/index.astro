---
import BaseLayout from '../layouts/BaseLayout.astro';
import Masthead from '../components/Masthead.astro';
import FeaturedPhoto from '../components/FeaturedPhoto.astro';
import Gallery from '../components/Gallery.astro';
import About from '../components/About.astro';
import Contact from '../components/Contact.astro';
import '../styles/global.scss';

import { getPhotos, getSettings, getSocialLinks, getAlbums } from '../lib/db';
import type { Photo, SocialLink, Album } from '../types/photo';

// Server-rendered so D1 bindings are available at request time
export const prerender = false;

const env = (Astro.locals as any).runtime?.env;
const db  = env?.DB || env?.tuesday_photos || env?.['tuesday-photos'];
const photosData: Photo[] = await getPhotos(db);
const settings: Record<string, string> = await getSettings(db);
const socialLinks: SocialLink[] = await getSocialLinks(db);
const albums: Album[] = await getAlbums(db);

const featuredPhoto = photosData.find((p) => p.is_featured === 1) || photosData[0];
const heroImageId = settings.hero_image_id || featuredPhoto?.public_id || '';
---

<BaseLayout>
  <Masthead heroPublicId={heroImageId} />

  <FeaturedPhoto
    photo={featuredPhoto}
  />

  <Gallery photos={photosData} albums={albums} />

  <About settings={settings} />

  <Contact links={socialLinks} />
</BaseLayout>
